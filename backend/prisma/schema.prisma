  goalUpdateTime    String  @default("09:00")

  // Group 5: Enhanced notification controls
  shoppingReminders Boolean @default(true)
  weeklyInsights    Boolean @default(true)
  quietHoursStart   String? // HH:mm, e.g. "22:00"
  quietHoursEnd     String? // HH:mm, e.g. "08:00"
  weekendsOff       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_settings")
}

model ProfilePreset {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Macro snapshot
  calories Int
  protein  Int
  carbs    Int
  fat      Int

  // Preference snapshot
