// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  password          String? // Hashed password (nullable for social login users)
  // Social login fields
  provider          String? // 'google', 'apple', or null for email/password
  providerId        String? // OAuth provider's user ID
  providerEmail     String? // Email from OAuth provider (may differ from email field)
  // Encryption metadata
  emailEncrypted    Boolean   @default(false) // Whether email is encrypted
  nameEncrypted     Boolean   @default(false) // Whether name is encrypted
  // ROADMAP 4.0 U14 — deterministic lookup hash for encrypted-email users.
  // HMAC-SHA256 of normalized email with EMAIL_LOOKUP_HMAC_KEY. Unique +
  // indexed so login / register / forgot-password do O(1) findUnique
  // instead of the O(N) `findMany({ where: { emailEncrypted: true }})`
  // scan-and-decrypt loop. Nullable for backfill compatibility; the
  // backfill script populates it for every existing row.
  emailLookupHash   String?   @unique
  // Password reset fields
  resetCode         String? // 6-digit code for password reset
  resetCodeExpiry   DateTime? // When the reset code expires
  profilePictureUrl String? // URL to uploaded profile picture
  // i18n — BCP 47 locale tag (e.g. 'en', 'es-MX', 'es-AR'). Auto-detected on
  // first message from Accept-Language; user can override in profile.
  // Resolves through resolveCoachLocale fallback chain server-side.
  locale            String?   @default("en")
  // ROADMAP 4.0 G1.2: bilingual coach voice override. NULL = inherit from
  // `locale`. Set explicitly when the user wants coach voice ≠ UI locale
  // (e.g. en-US device, but prefers Spanish food guidance).
  coachLocale       String?
  // ROADMAP 4.0 G2.4 — internal-only admin flag for founder-trip tooling.
  isAdmin           Boolean   @default(false)
  // ROADMAP 4.0 G2.1 — Sazon Travel mode. Home location + travel state
  // power "Eat the world" Today header when >50mi from home >24h.
  homeLatitude      Float?
  homeLongitude     Float?
  travelStartedAt   DateTime?
  travelCitySlug    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Preferences and goals
  preferences     UserPreferences?
  macroGoals      MacroGoals?
  physicalProfile UserPhysicalProfile?

  // Relationships
  savedRecipes            SavedRecipe[]
  collections             Collection[]
  feedback                RecipeFeedback[]
  cookEvents              CookEvent[]
  mealHistory             MealHistory[]
  mealPlans               MealPlan[]
  shoppingLists           ShoppingList[]
  shoppingAppIntegrations ShoppingAppIntegration[]
  ingredientCosts         IngredientCost[]
  // NEW: User-created recipes
  createdRecipes          Recipe[]
  // Meal prep portion tracking
  mealPrepPortions        MealPrepPortion[]
  mealPrepSessions        MealPrepSession[]
  mealPrepTemplates       MealPrepTemplate[]
  // Weight tracking
  weightLogs              WeightLog[]
  weightGoals             WeightGoal[]
  purchaseHistory         PurchaseHistory[]
  pantryItems             PantryItem[]
  mealPlanTemplates       MealPlanTemplate[]
  recipeViews             RecipeView[]
  cookingLogs             CookingLog[]
  recurringMeals          RecurringMeal[]
  notificationSettings    NotificationSettings?
  profilePresets          ProfilePreset[]
  searchQueries           SearchQuery[]
  pushTokens              PushToken[]
  stripeWebhookEvents     StripeWebhookEvent[]
  cravingSearchEvents     CravingSearchEvent[]

  // Group 10X: Build-a-Plate
  mealComponents      MealComponent[]
  composedPlates      ComposedPlate[]
  slotAffinities      SlotAffinity[]
  pairAffinities      PairAffinity[]
  leftoverInventory   LeftoverInventory[]
  plateShares         PlateShare[]
  plateSaves          PlateSave[]
  // Group 10X Phase 7: family mode
  householdMembers    HouseholdMember[]
  composedFamilyMeals ComposedFamilyMeal[]

  // Group 6: Email verification
  emailVerified Boolean @default(false)

  // Group 7: Stripe subscription
  stripeCustomerId   String?
  subscriptionStatus String    @default("free") // free | trialing | active | past_due | canceled
  subscriptionTier   String    @default("free") // free | premium
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?

  // ROADMAP 4.0 E4: RevenueCat (parallel to Stripe — same status/tier columns)
  revenueCatAppUserId     String?                  @unique
  cancelAtPeriodEnd       Boolean                  @default(false)
  revenueCatWebhookEvents RevenueCatWebhookEvent[]

  // ROADMAP 4.0 E9: Health platform integration (HealthKit / Health Connect)
  healthIntegration HealthIntegration?

  // ROADMAP 4.0 D13: per-day nutrient roll-ups
  dailyNutrientSnapshots DailyNutrientSnapshot[]

  // Group 8: Revenue Optimization
  cancellationSurveys CancellationSurvey[]

  // Group 10Y: Sazon Coach
  coachConversations  CoachConversation[]
  coachMessages       CoachMessage[]
  // Group 10Y Phase 6: Coach memory & weekly check-in
  coachMemories       CoachMemory[]
  lastWeeklyCheckinAt DateTime?

  // ROADMAP 4.0 J5: discovery milestones (single-fire celebrations)
  // JSON-stringified array of milestone keys the user has crossed for the
  // first time (e.g. ["first-photo","first-leftover","first-appliance:ninja-creami"]).
  // Stored as String? because SQLite has no native Json type.
  discoveryMilestones String?

  // ROADMAP 4.0 F1: social graph for "Cook a friend's plate" feed
  follows   UserFollow[] @relation("FollowerRelation")
  followers UserFollow[] @relation("FollowingRelation")

  // ROADMAP 4.0 TB3.1 — back-relation for recommender events.
  recommenderEvents RecommenderEvent[]

  // ROADMAP 4.0 G2.3 — back-relation for travel journal entries.
  travelJournalEntries TravelJournalEntry[]

  // ROADMAP 4.0 G2.4 — back-relation for founder-trip curation tasks.
  curationTasks LocalCurationTask[]

  // ROADMAP 4.0 IG0.2 — back-relation for the ingredient event stream.
  ingredientEvents IngredientEvent[]

  // ROADMAP 4.0 IG2.1 / IG3.1 — back-relations for adjacency + cadence.
  ingredientCoOccurrence IngredientCoOccurrence[]
  ingredientCadence      IngredientCadence[]

  // ROADMAP 4.0 IG9.2 — back-relation for the ingredient-recommender daily rollup.
  ingredientRecommenderDaily IngredientRecommenderDaily[]

  // ROADMAP 4.0 T0.1 — Tonight Mode opt-in (gated by SAZON_TONIGHT_MODE env flag).
  tonightModeEnabled    Boolean   @default(false)
  tonightModePromptedAt DateTime?

  // Tier L H2 — refresh-token relation (rotation + revocation tracking).
  refreshTokens RefreshToken[]

  @@map("users")
}

// Tier L H2 — server-side refresh tokens enable short access-token TTLs
// (15min) without forcing re-login every 15 minutes, plus give us a hook
// for revocation (logout, password reset, account compromise).
//
// Storage: only the SHA-256 hash of the token is persisted. The plaintext
// is returned to the client at issue time and never stored. This means a
// DB leak doesn't compromise sessions, and the token is opaque (not a
// JWT — no fields to tamper with).
//
// Rotation: every successful /auth/refresh issues a new refresh token and
// revokes the previous one (single-use, replacedById links the chain).
model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SHA-256 hex digest of the raw refresh token. Indexed for O(log n) lookup.
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  // When this token was rotated, the new token's id. Null until rotated.
  replacedById String?
  // Optional metadata for audit / "active sessions" UI later.
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Banned ingredients and preferences
  bannedIngredients   BannedIngredient[]
  likedCuisines       LikedCuisine[]
  dietaryRestrictions DietaryRestriction[]
  preferredSuperfoods PreferredSuperfood[] // Superfood preferences (Phase 6, Group 12a)
  cookTimePreference  Int // in minutes
  spiceLevel          String? // mild, medium, spicy

  // Cooking context (Group 5: Profile Advanced)
  cookingSkillLevel String? // beginner | home_cook | confident | chef
  weekdayCookTime   Int? // max cooking minutes on weekdays
  weekendCookTime   Int? // max cooking minutes on weekends

  // Group 10I: Cooking Journey — user-seeded cuisines they already know how to cook
  // (JSON-stringified array, e.g. '["Italian","Thai"]') — merged into cuisinesExplored stat
  seededCuisines String?

  // Group 10S: Kitchen IQ — JSON-stringified array of card IDs the user has already
  // been notified about as "unlocked"; used to compute `newUnlocks` diff on next read.
  lastCheckedUnlocks String?

  // Group 10Y Phase 6: weekly check-in opt-in for Pro Coach
  weeklyCheckinOptIn Boolean @default(false)

  // ROADMAP 4.0 C5 — Sazon memory writeback to structured stack.
  // Goal phase the user has declared: 'cut' | 'maintain' | 'bulk' | 'recomp'.
  // Default null = lifestyle user with no specific phase. Coach voice never
  // uses this phrase set in user-facing copy (see C11 voice rules).
  goalPhase         String?
  // JSON-stringified flag map of structured intents extracted from
  // CoachMemory writeback ({cuisineVarietyBoost, proteinTargetNudge,
  // fiberTargetNudge}). Drives prompt addenda + ranking nudges downstream.
  structuredIntents String?

  // Cost tracking & budget preferences (Phase 6, Group 13)
  maxRecipeCost      Float? // Maximum cost per recipe
  maxMealCost        Float? // Maximum cost per meal
  maxDailyFoodBudget Float? // Maximum daily food budget
  currency           String? @default("USD")

  // Location preferences for store lookup
  zipCode             String? // User's zip code
  latitude            Float? // GPS latitude
  longitude           Float? // GPS longitude
  useLocationServices Boolean? @default(false) // Whether to use GPS location

  // ROADMAP 4.0 N8.2 — central privacy opt-out for cross-user data flows.
  // Controls IG1.1 cross-user co-purchase aggregation, HX2.3 cohort overlay
  // (friend names), F1 friends feed visibility. Default opt-IN with a
  // k-anonymity ≥ 30 floor for aggregations; opt-out hides all three.
  privacyShareOptIn Boolean? @default(true)

  // ROADMAP 4.0 N5.2 — onboarding parity (engine signals captured at signup).
  // Each field maps to a downstream ranker input that previously cold-started
  // at zero. All optional; never block onboarding completion.
  cookFrequency         String? // 'rare' | 'occasional' | 'frequent' | 'daily' — seeds skill-tier + macro distribution prior
  notificationWindow    String? // 'morning' | 'evening' — seeds C12 cook-hour window
  socialOptIn           Boolean? @default(false) // 'happy to see friends here?' — seeds F1 + HX2.3 social opt-in
  pantryLeaningCuisines String? // JSON-stringified array, e.g. '["Mediterranean","Asian"]' — seeds IG10.1 cold-start
  leftoverAccept        Boolean? @default(true) // 'ok with leftovers?' — seeds WK2.1 carry-over default

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// Separate tables for array-like fields
model BannedIngredient {
  id           String           @id @default(cuid())
  preference   UserPreferences? @relation(fields: [preferenceId], references: [id], onDelete: Cascade)
  preferenceId String?
  name         String

  @@map("banned_ingredients")
}

model LikedCuisine {
  id           String           @id @default(cuid())
  preference   UserPreferences? @relation(fields: [preferenceId], references: [id], onDelete: Cascade)
  preferenceId String?
  name         String

  @@map("liked_cuisines")
}

model DietaryRestriction {
  id           String           @id @default(cuid())
  preference   UserPreferences? @relation(fields: [preferenceId], references: [id], onDelete: Cascade)
  preferenceId String?
  name         String
  severity     String           @default("strict") // strict | prefer_avoid

  @@map("dietary_restrictions")
}

model PreferredSuperfood {
  id           String           @id @default(cuid())
  preference   UserPreferences? @relation(fields: [preferenceId], references: [id], onDelete: Cascade)
  preferenceId String?
  category     String // Superfood category (e.g., "beans", "oliveOil", "salmon", etc.)

  @@map("preferred_superfoods")
}

model MacroGoals {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  calories Int
  protein  Int
  carbs    Int
  fat      Int
  fiber    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("macro_goals")
}

model UserPhysicalProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Physical measurements
  gender   String // male, female, other
  age      Int
  heightCm Float // Height in centimeters
  weightKg Float // Weight in kilograms

  // Activity and goals
  activityLevel String // sedentary, lightly_active, moderately_active, very_active, extra_active
  fitnessGoal   String // lose_weight, maintain, gain_muscle, gain_weight

  // Calculated metrics (stored for tracking changes over time)
  bmr            Float? // Basal Metabolic Rate
  tdee           Float? // Total Daily Energy Expenditure
  targetWeightKg Float? // Target weight if applicable

  // Additional optional data for future metabolism tracking
  bodyFatPercentage Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_physical_profiles")
}

model Recipe {
  id          String  @id @default(cuid())
  title       String
  description String
  cookTime    Int // in minutes
  cuisine     String
  mealType    String? // "breakfast", "lunch", "dinner", "snack", "dessert"
  difficulty  String  @default("medium") // "easy", "medium", "hard"
  servings    Int     @default(1)
  imageUrl    String?

  // Unsplash attribution (required for production API compliance)
  unsplashPhotoId              String? // Unsplash photo ID
  unsplashDownloadLocation     String? // For triggering download events
  unsplashPhotographerName     String? // Photographer's name
  unsplashPhotographerUsername String? // Photographer's username
  unsplashAttributionText      String? // "Photo by {name} on Unsplash"
  unsplashUrl                  String? // Link to photo on Unsplash (hotlinked per guidelines)

  // Macro nutrients
  calories Int
  protein  Int
  carbs    Int
  fat      Int
  fiber    Int?
  sugar    Int?

  // NEW: Recipe ownership
  userId        String? // Null for system recipes, set for user-created recipes
  user          User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  isUserCreated Boolean @default(false)

  // Recipe source tracking
  source String @default("database") // "database", "user-created", "ai-generated", "external", "user-modified"

  // Fork lineage — tracks which recipe this was forked/modified from
  parentRecipeId String?
  parentRecipe   Recipe?  @relation("RecipeForks", fields: [parentRecipeId], references: [id], onDelete: SetNull)
  forks          Recipe[] @relation("RecipeForks")

  // External data integration (Phase 5)
  externalId       String? // ID from external source (e.g., Spoonacular)
  externalSource   String? // Source name (e.g., "spoonacular", "edamam")
  qualityScore     Float? // Quality rating from external source (0-100)
  popularityScore  Float? // Popularity metric from external source (0-100)
  healthScore      Float? // Health score from external API
  aggregateLikes   Int? // Total likes/favorites from external source
  spoonacularScore Float? // Spoonacular-specific score
  pricePerServing  Float? // Cost per serving from external API
  sourceUrl        String? // Original recipe URL
  sourceName       String? // Original source attribution
  lastEnriched     DateTime? // Last time external data was fetched

  // Cost tracking (Phase 6, Group 13)
  estimatedCost           Float? // Estimated total cost of recipe
  estimatedCostPerServing Float? // Estimated cost per serving
  costSource              String? // "user", "api", "calculated", "estimated"

  // Meal prep suitability (Phase 6, Group 14)
  mealPrepSuitable   Boolean? @default(false) // General meal prep suitability
  freezable          Boolean? @default(false) // Can be frozen
  batchFriendly      Boolean? @default(false) // Good for batch cooking
  weeklyPrepFriendly Boolean? @default(false) // Good for weekly meal prep
  mealPrepScore      Float? // 0-100 score for meal prep suitability

  // Storage instructions
  storageInstructions  String? // Storage instructions (e.g., "Refrigerate for up to 5 days", "Freeze for up to 3 months")
  fridgeStorageDays    Int? // Number of days recipe can be stored in fridge
  freezerStorageMonths Int? // Number of months recipe can be stored in freezer
  shelfStable          Boolean? @default(false) // Can be stored at room temperature

  // Recipe content
  ingredients  RecipeIngredient[]
  instructions RecipeInstruction[]

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ROADMAP 4.0 F3 — appliance categories. JSON-stringified array of
  // appliance keys (e.g. ["ninja_creami","air_fryer"]). Tagged via the
  // heuristic in applianceTaggerService and surfaced as filter chips.
  appliances String?

  // ROADMAP 4.0 D12 — free-text recipe tags. JSON-stringified array of
  // tag keys (e.g. ["cravings_made_real","glazed_bite"]). Used by smart
  // collections (Cravings Made Real, Glazed Protein Bites family).
  tagsJson String?

  // Relationships
  feedback          RecipeFeedback[]
  cookEvents        CookEvent[]
  savedRecipes      SavedRecipe[]
  mealHistory       MealHistory[]
  meals             Meal[]
  mealPrepPortions  MealPrepPortion[] // Meal prep portion tracking
  mealPrepTemplates MealPrepTemplate[] // Meal prep templates
  shoppingListItems ShoppingListItem[] // Shopping list items from this recipe
  templateMeals     TemplateMeal[] // Meals in meal plan templates
  recipeViews       RecipeView[]
  cookingLogs       CookingLog[]
  recurringMeals    RecurringMeal[]
  // ROADMAP 4.0 D13 — back-relation for the lazy nutrient aggregate.
  nutrientAggregate RecipeNutrientAggregate?

  // ROADMAP 4.0 D2 — back-relation for the quality scorecard.
  qualityScoreEntry RecipeQualityScore?

  // ROADMAP 4.0 D3 — canonical cuisine taxonomy. Original `cuisine`
  // string is preserved (reversibility); these two are written by the
  // migration script and used by D5 coverage reporting.
  canonicalCuisine String?
  subCuisine       String?

  // ROADMAP 4.0 D7 — soft delete + back-relation to audit log.
  deletedAt       DateTime?
  rebuildRequired Boolean         @default(false)
  deletionLog     RecipeDeletion?

  // ROADMAP 4.0 D11 — cultural authenticity tier.
  // 'authentic' | 'adapted' | 'inspired' | null. Surfaceability gated
  // by authenticityGateService — adapted/inspired require ≥1 authentic
  // peer in the same canonical×archetype slot.
  authenticityTier String?

  // ROADMAP 4.0 TB0 — 64-dim Food.com / fallback content embedding.
  // Stored as raw bytes (Float32Array, 64 × 4 = 256 bytes). Written by
  // alignCatalog.ts (TB0.3); consumed by retrieveCandidates (TB1.2) and
  // dedupeScorer (D2.5).
  embedding          Bytes?
  embeddingSource    String? // 'foodcom' | 'openai' | null
  embeddingUpdatedAt DateTime?

  // ROADMAP 4.0 TB3.1 — back-relations for recommender event logging.
  recommenderEvents    RecommenderEvent[]    @relation("PickedRecipe")
  recommenderRunnerUps RecommenderRunnerUp[]

  // ROADMAP 4.0 J18.1 — recipe variants as siblings.
  variantsAsSource  RecipeVariant[] @relation("RecipeVariantSource")
  variantsAsSibling RecipeVariant[] @relation("RecipeVariantSibling")

  // Performance indexes for recipe queries
  @@index([userId])
  @@index([isUserCreated])
  @@index([cuisine])
  @@index([mealType])
  @@index([cookTime])
  @@index([isUserCreated, cuisine])
  @@index([isUserCreated, mealType])
  @@index([isUserCreated, cuisine, mealType])
  @@index([canonicalCuisine])
  @@index([canonicalCuisine, subCuisine])
  @@index([canonicalCuisine, authenticityTier])
  @@index([createdAt])
  @@map("recipes")
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String
  text     String
  order    Int

  // Cost tracking (Phase 6, Group 13)
  estimatedCost Float? // Estimated cost for this ingredient
  unitCost      Float? // Cost per unit (e.g., per lb, per cup)

  @@index([recipeId]) // H6: every recipe-list `include: { ingredients }` would full-scan this table without it
  @@map("recipe_ingredients")
}

model RecipeInstruction {
  id            String  @id @default(cuid())
  recipe        Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId      String
  text          String
  step          Int
  // ROADMAP 4.0 C2 — optional inline swap; surfaced only when it matches user gap.
  // JSON shape: {type: 'fiber'|'protein'|'calorie', text: string, deltaMacro: {fiber?: number, protein?: number, calories?: number}}
  healthierSwap String?

  @@index([recipeId]) // H6: every recipe-list `include: { instructions }` would full-scan this table without it
  @@map("recipe_instructions")
}

model RecipeFeedback {
  id       String @id @default(cuid())
  recipeId String
  userId   String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  liked    Boolean @default(false)
  disliked Boolean @default(false)
  saved    Boolean @default(false)
  consumed Boolean @default(false)

  dislikeReason String? // 'not_my_style' | 'too_complex' | 'missing_ingredients' | 'already_tried'

  createdAt DateTime @default(now())

  @@unique([recipeId, userId])
  @@index([userId, liked])
  @@index([userId, disliked])
  @@map("recipe_feedback")
}

// W-A1 — Cook Log. Append-only event stream (one row per scale/swap/made-it/
// note/outcome), unlike RecipeFeedback's one-row-per-(recipe,user) state.
// recipeId is nullable + SetNull so a cook can be logged without a Sazon
// recipe (the §9a path: organize a Claude-assisted cook session) and survive
// recipe deletion. This is the moat substrate — see
// plans/office-hours/cooking-mode.md.
model CookEvent {
  id       String  @id @default(cuid())
  userId   String
  recipeId String?
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  type    String // 'scale' | 'swap' | 'made_it' | 'note' | 'outcome'
  payload String // JSON-serialized detail (SQLite has no Json type — see
  // cookEventService for the (de)serialize helpers; matches the codebase's
  // serializeJsonColumnSafe pattern)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, recipeId])
  @@map("cook_events")
}

model SavedRecipe {
  id       String @id @default(cuid())
  recipeId String
  userId   String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  savedDate DateTime @default(now())

  // Cookbook Quick Wins
  notes  String? // Personal notes ("needs more garlic", "kids loved it")
  rating Int? // Personal 1-5 star rating

  // Many-to-many relationship with collections via RecipeCollection
  recipeCollections RecipeCollection[]

  @@unique([recipeId, userId])
  @@index([userId, savedDate])
  @@map("saved_recipes")
}

model RecipeView {
  id       String   @id @default(cuid())
  recipeId String
  userId   String
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@unique([recipeId, userId])
  @@index([userId, viewedAt])
  @@map("recipe_views")
}

model CookingLog {
  id       String   @id @default(cuid())
  recipeId String
  userId   String
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cookedAt DateTime @default(now())
  notes    String?

  @@index([userId, recipeId])
  @@index([userId, cookedAt])
  @@map("cooking_logs")
}

model Collection {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  coverImageUrl String?
  isPinned      Boolean  @default(false)
  sortOrder     Int      @default(0)
  isDefault     Boolean  @default(false)
  category      String? // meal_type | cuisine | mood | dietary | seasonal | custom
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Many-to-many relationship with recipes via RecipeCollection
  recipeCollections RecipeCollection[]

  @@unique([userId, name])
  @@map("collections")
}

// Join table for many-to-many relationship between recipes and collections
model RecipeCollection {
  id            String      @id @default(cuid())
  savedRecipeId String
  collectionId  String
  savedRecipe   SavedRecipe @relation(fields: [savedRecipeId], references: [id], onDelete: Cascade)
  collection    Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  addedAt       DateTime    @default(now())

  @@unique([savedRecipeId, collectionId])
  @@map("recipe_collections")
}

model MealHistory {
  id       String @id @default(cuid())
  recipeId String
  userId   String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date     DateTime @default(now())
  consumed Boolean  @default(false)
  feedback String? // liked, disliked, null

  @@index([userId, consumed])
  @@index([userId, date])
  @@map("meal_history")
}

model MealPlan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String?
  planningMode String? // enum 'cut' | 'maintain' | 'build' — enforced at app layer via PlanningModeSchema in mealPlanSchemas.ts (SQLite has no enum type)
  startDate    DateTime
  endDate      DateTime

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meals Meal[]

  @@index([userId, isActive])
  @@index([userId, startDate])
  @@map("meal_plans")
}

model Meal {
  id         String   @id @default(cuid())
  mealPlanId String
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  date     DateTime
  mealType String
  recipeId String?
  // M4: explicit SetNull. Was relying on Prisma's default-for-optional behavior
  // which is opaque; making it explicit prevents future surprise when hard
  // recipe deletes ship (today recipes are soft-deleted so this is dormant).
  recipe   Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  foodItemId String?
  foodItem   FoodItem? @relation(fields: [foodItemId], references: [id])

  customName        String?
  customDescription String?
  customCalories    Int?
  customProtein     Float?
  customCarbs       Float?
  customFat         Float?

  isCompleted Boolean   @default(false)
  completedAt DateTime?

  rating Int?
  notes  String?

  // 10F: Taste feedback
  tasteRating Int? // 1-5 emoji scale
  flavorTags  String? // JSON array of selected tags (e.g. '["Perfect spice","Great texture"]')

  isFromRecurring Boolean @default(false)
  recurringMealId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // M3: composite index for the two hottest queries — `findMany({ where:
  // { mealPlanId } })` on plan load and date-scoped day views. The
  // `(mealPlanId, date)` ordering covers both because Meal queries are
  // always plan-scoped first.
  @@index([mealPlanId, date])
  @@map("meals")
}

// Meal Plan Templates (Group 18b)
model MealPlanTemplate {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  goal        String? // "weight_loss", "muscle_gain", "balanced", "budget", null=custom
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meals TemplateMeal[]

  @@map("meal_plan_templates")
}

model TemplateMeal {
  id         String           @id @default(cuid())
  templateId String
  template   MealPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  dayIndex Int // 0-6 (relative day offset within the week)
  mealType String // "breakfast", "lunch", "dinner", "snack"
  recipeId String?
  // M4: explicit SetNull (matches Meal.recipe). Same rationale.
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  customName        String?
  customDescription String?
  customCalories    Int?
  customProtein     Float?
  customCarbs       Float?
  customFat         Float?

  createdAt DateTime @default(now())

  @@map("template_meals")
}

// Recurring Meals (Group 18b)
model RecurringMeal {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealType   String // "breakfast" | "lunch" | "dinner" | "snack"
  daysOfWeek String // Comma-separated day indices: "1,2,3,4,5" = Mon-Fri
  recipeId   String?
  recipe     Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  title      String? // Custom meal title (when no recipe)
  calories   Int?
  protein    Float?
  carbs      Float?
  fat        Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, isActive])
  @@map("recurring_meals")
}

// Search Query Tracking (Group 18g - Search 2.0)
model SearchQuery {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query       String
  resultCount Int      @default(0)
  searchedAt  DateTime @default(now())

  @@index([userId, searchedAt])
  @@index([query, searchedAt])
  @@map("search_queries")
}

// Meal Prep Portion Tracking (Phase 6, Group 14)
model MealPrepPortion {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // Portion allocation
  totalServings    Int // Total servings made
  servingsToFreeze Int // Number of servings frozen
  servingsForWeek  Int // Number of servings for immediate use (refrigerated)

  // Current status
  frozenServingsRemaining Int @default(0) // How many frozen servings are left
  freshServingsRemaining  Int @default(0) // How many fresh servings are left

  // Tracking
  prepDate          DateTime  @default(now()) // When meal prep was done
  freezeDate        DateTime? // When portions were frozen
  expiryDate        DateTime? // When fresh portions expire
  freezerExpiryDate DateTime? // When frozen portions expire

  // Notes
  notes String?

  // Consumption tracking
  consumedPortions MealPrepConsumption[]

  // Meal prep session (optional - links to scheduled prep session)
  mealPrepSessionId String?
  mealPrepSession   MealPrepSession? @relation(fields: [mealPrepSessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId]) // M3: every meal-prep + shopping-list call filters on userId
  @@map("meal_prep_portions")
}

// Meal Prep Session Planning (Phase 6, Group 14)
model MealPrepSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Session scheduling
  scheduledDate DateTime // When the meal prep session is scheduled
  scheduledTime String? // Optional time (e.g., "10:00 AM")
  duration      Int? // Estimated duration in minutes
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?

  // Session details
  notes   String?
  recipes MealPrepPortion[] // Recipes being prepped in this session

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId]) // M3: session list is always userId-scoped
  @@map("meal_prep_sessions")
}

// Meal Prep Recipe Templates (Phase 6, Group 14)
model MealPrepTemplate {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // Default meal prep configuration
  defaultServings         Int // Default total servings for meal prep
  defaultServingsToFreeze Int? // Default servings to freeze
  defaultServingsForWeek  Int? // Default servings for immediate use

  // Template metadata
  name       String? // Custom name for this template (e.g., "Weekly Batch")
  notes      String? // Notes or tips for this meal prep
  isFavorite Boolean @default(false) // Quick access favorite

  // Usage tracking
  timesUsed Int       @default(0) // How many times this template has been used
  lastUsed  DateTime? // Last time this template was used

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, recipeId]) // One template per recipe per user
  @@map("meal_prep_templates")
}

// Track consumption of meal prep portions
model MealPrepConsumption {
  id                String          @id @default(cuid())
  mealPrepPortionId String
  mealPrepPortion   MealPrepPortion @relation(fields: [mealPrepPortionId], references: [id], onDelete: Cascade)

  servings     Int // Number of servings consumed
  portionType  String // "frozen" or "fresh"
  consumedDate DateTime @default(now())
  notes        String?

  createdAt DateTime @default(now())

  @@map("meal_prep_consumption")
}

model ScoringWeights {
  id String @id @default(cuid())

  // Scoring weights (70% macros, 30% taste by default)
  macroWeight           Float @default(0.7)
  tasteWeight           Float @default(0.3)
  cookTimeWeight        Float @default(0.1)
  ingredientMatchWeight Float @default(0.1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("scoring_weights")
}

model ShoppingList {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String    @default("My Shopping List")
  isActive        Boolean   @default(true)
  sourceRecipeIds String? // JSON array of recipe IDs used to generate this list
  // Group 10Q-ListMgmt: lifecycle fields
  archivedAt      DateTime?
  tier            String    @default("active") // "active" | "archived" | "older"
  summaryStats    String? // JSON string, populated when tier flips to "older"
  // Group 10Q-ListMgmt: auto-name provenance — cleared when user manually renames
  autoNamedFrom   String? // JSON: { source: "recipes"|"mealPlan"|"items", payload: any }
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items ShoppingListItem[]

  @@index([userId, isActive])
  @@index([userId, tier])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id              String       @id @default(cuid())
  shoppingListId  String
  shoppingList    ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  name            String
  quantity        String
  category        String?
  purchased       Boolean      @default(false)
  notes           String?
  price           Float?
  photoUrl        String?
  recipeId        String?
  recipe          Recipe?      @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  // Group 10Q: source recipe IDs (JSON array) — tracks which recipes contributed this ingredient
  sourceRecipeIds String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([shoppingListId])
  @@index([shoppingListId, purchased])
  @@map("shopping_list_items")
}

// Group 10Q: tracks ingredients deleted from a recipe-sourced list ("Missing for <recipe>" banner)
model MissingIngredient {
  id             String   @id @default(cuid())
  userId         String
  recipeId       String
  ingredientName String
  deletedAt      DateTime @default(now())
  dismissed      Boolean  @default(false)

  @@index([userId, recipeId])
  @@index([userId, dismissed])
  @@map("missing_ingredients")
}

// Group 10Q: share a shopping list via a deep-link token
model ShoppingListShare {
  id        String   @id @default(cuid())
  listId    String
  token     String   @unique
  createdBy String
  expiresAt DateTime
  usedBy    String   @default("[]") // JSON array of user IDs
  maxUses   Int      @default(10)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([listId])
  @@map("shopping_list_shares")
}

// Group 10Q-ListMgmt: records when a user dismisses a merge suggestion pair
// Prevents the same pair from being re-suggested.
model MergeDismissal {
  id           String   @id @default(cuid())
  userId       String
  sourceListId String
  targetListId String
  dismissedAt  DateTime @default(now())

  @@unique([userId, sourceListId, targetListId])
  @@index([userId, targetListId])
  @@map("merge_dismissals")
}

model PurchaseHistory {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemName        String
  quantity        String   @default("1")
  category        String?
  purchaseCount   Int      @default(1)
  lastPurchasedAt DateTime @default(now())
  isFavorite      Boolean  @default(false)
  lastPrice       Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, itemName])
  @@index([userId, purchaseCount])
  @@index([userId, isFavorite])
  @@map("purchase_history")
}

model PantryItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  category  String?
  source    String   @default("manual") // 'manual' | 'shopping' | 'cooking'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ROADMAP 4.0 IG0.1 — Pantry data model upgrade. All nullable so existing
  // rows stay valid; depletion (IG3) + use-it-up (IG4) gate on these.
  quantity          Float?
  unit              String? // 'g' | 'oz' | 'lb' | 'cup' | 'piece' | etc.
  expiryHint        Int? // days-from-purchase before going bad (heuristic)
  lastConsumedAt    DateTime?
  addedFromRecipeId String?

  @@unique([userId, name])
  @@index([userId])
  @@map("pantry_items")
}

model ShoppingAppIntegration {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appName      String // e.g., "instacart", "walmart", "kroger"
  apiKey       String?
  accessToken  String?
  refreshToken String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, appName])
  @@map("shopping_app_integrations")
}

model IngredientCost {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredientName String
  unitCost       Float
  unit           String   @default("lb") // lb, oz, cup, piece, etc.
  store          String?
  location       String?
  lastUpdated    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([userId]) // M3: 4 call sites filter by userId; was full-scanning
  @@map("ingredient_costs")
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  weightKg  Float
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@map("weight_logs")
}

model WeightGoal {
  id                     String   @id @default(cuid())
  userId                 String
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentWeightKg        Float
  targetWeightKg         Float
  targetDate             DateTime
  dailyCalorieDeficit    Float
  requiredCaloriesPerDay Float
  requiredStepsPerDay    Int
  caloriesFromSteps      Float
  caloriesFromDiet       Float
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId, isActive])
  @@map("weight_goals")
}

model NotificationSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mealReminders     Boolean @default(true)
  mealReminderTimes String  @default("08:00,12:00,18:00") // Comma-separated HH:mm times
  newRecipes        Boolean @default(true)
  goalUpdates       Boolean @default(false)
  goalUpdateDay     String  @default("Monday")
  goalUpdateTime    String  @default("09:00")

  // Group 5: Enhanced notification controls
  shoppingReminders Boolean @default(true)
  weeklyInsights    Boolean @default(true)
  quietHoursStart   String? // HH:mm, e.g. "22:00"
  quietHoursEnd     String? // HH:mm, e.g. "08:00"
  weekendsOff       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_settings")
}

model ProfilePreset {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Macro snapshot
  calories Int
  protein  Int
  carbs    Int
  fat      Int

  // Preference snapshot
  activityLevel      String?
  fitnessGoal        String?
  maxDailyFoodBudget Float?
  currency           String? @default("USD")

  isActive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId, isActive])
  @@map("profile_presets")
}

// Stripe webhook event log (Group 7: Stripe Integration)
model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String // e.g. "customer.subscription.updated"
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  processedAt   DateTime @default(now())
  data          String // JSON string of the event payload for audit trail

  @@index([userId])
  @@index([type])
  @@map("stripe_webhook_events")
}

// ROADMAP 4.0 E9: Health platform integration. Per-user record of which
// platform is wired up + which signals are enabled. Read-only at v1; meal
// write-back gated behind a separate Apple review checkpoint.
model HealthIntegration {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform                   String // "healthkit" | "healthconnect"
  weightSyncEnabled          Boolean   @default(false)
  bodyCompositionSyncEnabled Boolean   @default(false)
  activitySyncEnabled        Boolean   @default(false)
  sleepSyncEnabled           Boolean   @default(false)
  mealWriteEnabled           Boolean   @default(false) // gated until Apple checkpoint
  lastSyncAt                 DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@map("health_integrations")
}

// ROADMAP 4.0 E4: RevenueCat webhook event log (mirrors StripeWebhookEvent)
model RevenueCatWebhookEvent {
  id                String   @id @default(cuid())
  revenueCatEventId String   @unique
  type              String // INITIAL_PURCHASE | RENEWAL | CANCELLATION | EXPIRATION | TRIAL_STARTED | TRIAL_CONVERTED | BILLING_ISSUE | …
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  processedAt       DateTime @default(now())
  data              String // JSON string of the event payload for audit trail

  @@index([userId])
  @@index([type])
  @@map("revenuecat_webhook_events")
}

// Cancellation survey response (Group 8: Revenue Optimization)
model CancellationSurvey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String // too_expensive | not_using | missing_feature | other
  feedback  String? // free-text for "missing_feature" reason
  action    String // cancel | pause
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("cancellation_surveys")
}

// 10D-ii: Craving search event tracking for future relevance scoring
model CravingSearchEvent {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cravingQuery String
  recipeId     String
  action       String // "tap" | "save" | "cook"
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([cravingQuery])
  @@map("craving_search_events")
}

// Push notification device tokens (Group 6: Growth & Marketing)
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String // "ios" | "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("push_tokens")
}

// Group 10X: Build-a-Plate — composable meal components
model MealComponent {
  id                      String   @id @default(cuid())
  slot                    String // protein | base | vegetable | sauce | garnish
  name                    String
  description             String?
  defaultPortionGrams     Float
  caloriesPerPortion      Float
  proteinG                Float
  carbsG                  Float
  fatG                    Float
  fiberG                  Float?
  estimatedCostPerPortion Float?
  cuisineTags             String // JSON array, e.g. '["Mediterranean","Asian"]'
  dietaryTags             String // JSON array, e.g. '["vegan","gluten_free"]'
  cookMethodHint          String // roast | pan_sear | simmer | raw | mix
  cookTimeMinutes         Int      @default(0)
  equipmentNeeded         String   @default("[]") // JSON array: ["oven","stovetop_burner","none","mixing_bowl"]
  pantryIngredientNames   String // JSON array used to compute pantry coverage
  imageUrl                String?
  isUserCreated           Boolean  @default(false)
  userId                  String?
  user                    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt               DateTime @default(now())

  // Phase 4: affinity back-references
  slotAffinities SlotAffinity[]

  // Phase 6: leftover inventory back-reference
  leftovers LeftoverInventory[]

  // 10X-Deferred: variant chip row (roasted / steamed / raw / pickled, etc.)
  variants MealComponentVariant[]

  @@index([slot])
  @@index([userId])
  @@map("meal_components")
}

// Group 10X-Deferred: variants of an existing MealComponent
// (e.g. carrots → roasted_carrots, steamed_carrots, raw_carrot_ribbons, pickled_carrots).
model MealComponentVariant {
  id                     String        @id @default(cuid())
  componentId            String
  component              MealComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  variantKey             String // "roasted" | "steamed" | "raw" | "pickled" ...
  displayName            String // "Roasted Carrots"
  cookTimeMinutes        Int
  caloriePerPortionDelta Int // relative to base; can be negative
  equipmentNeeded        String? // "oven" | "stovetop" | "none" ...
  flavorProfile          String? // "sweet,charred"
  compatibilityScores    String? // JSON: { proteinId|sauceId: 0.0-1.0 }
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([componentId, variantKey])
  @@index([componentId])
  @@map("meal_component_variants")
}

// Group 10X Phase 4: per-user per-component slot affinity scores
// Phase 7+: optional householdMemberId narrows affinity to a specific kid/adult
// — kid plate must adapt to *this* kid, not a generic kid template (N=1).
// householdMemberId === null means "the account holder's own affinity".
model SlotAffinity {
  id                String           @id @default(cuid())
  userId            String
  componentId       String
  householdMemberId String?
  slot              String
  score             Float            @default(0)
  sampleCount       Int              @default(0)
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  component         MealComponent    @relation(fields: [componentId], references: [id], onDelete: Cascade)
  householdMember   HouseholdMember? @relation(fields: [householdMemberId], references: [id], onDelete: Cascade)

  @@unique([userId, householdMemberId, componentId])
  @@index([userId, slot])
  @@index([householdMemberId, slot])
  @@map("slot_affinities")
}

// Group 10X Phase 4: per-user per-pair component co-occurrence affinity scores
model PairAffinity {
  id           String   @id @default(cuid())
  userId       String
  componentIdA String
  componentIdB String
  score        Float    @default(0)
  sampleCount  Int      @default(0)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, componentIdA, componentIdB])
  @@index([userId])
  @@map("pair_affinities")
}

// Group 10X Phase 8: shareable plate links
model PlateShare {
  id        String        @id @default(cuid())
  slug      String        @unique
  plateId   String
  plate     ComposedPlate @relation(fields: [plateId], references: [id], onDelete: Cascade)
  createdBy String
  user      User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([createdBy])
  @@map("plate_shares")
}

// Group 10X Phase 8: per-user save of someone else's shared plate
model PlateSave {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plateId   String
  plate     ComposedPlate @relation(fields: [plateId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([userId, plateId])
  @@index([plateId, createdAt])
  @@map("plate_saves")
}

// Group 10X Phase 6: leftover inventory — components remaining after a cook
model LeftoverInventory {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  componentId       String
  component         MealComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  slot              String
  portionsRemaining Float
  sourcePlateId     String?
  createdAt         DateTime      @default(now())
  expiresAt         DateTime

  @@index([userId, expiresAt])
  @@index([componentId])
  @@map("leftover_inventory")
}

// ROADMAP 4.0 J18.1 — Recipe variants as siblings, not replacements.
// A directional join between two recipes: `recipe` is the source, `sibling`
// is a related variant ("same dish, different technique"). The `tag` is one
// of: weeknight | sunday | campfire | lighter — validated in code via
// `RECIPE_VARIANT_TAGS`. Other tags are rejected by the service layer.
model RecipeVariant {
  id              String   @id @default(cuid())
  recipeId        String
  recipe          Recipe   @relation("RecipeVariantSource", fields: [recipeId], references: [id], onDelete: Cascade)
  siblingRecipeId String
  sibling         Recipe   @relation("RecipeVariantSibling", fields: [siblingRecipeId], references: [id], onDelete: Cascade)
  tag             String
  techniqueLine   String?
  createdAt       DateTime @default(now())

  @@unique([recipeId, siblingRecipeId, tag])
  @@index([recipeId])
  @@map("recipe_variants")
}

model ComposedPlate {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String?
  componentIds          String // JSON: [{slot, componentId, portionMultiplier}]
  totalCalories         Float
  totalProtein          Float
  totalCarbs            Float
  totalFat              Float
  totalCost             Float?
  pantryCoveragePercent Float
  recipeId              String?
  // ROADMAP 4.0 J17.2 — plate archetype (few_small_things | standard | null).
  // Discovery framing: "A few small things" surfaced as a STYLE, never a
  // health pitch. Null on legacy plates created before the field existed.
  archetype             String?
  createdAt             DateTime @default(now())

  // Phase 8: social
  shares PlateShare[]
  saves  PlateSave[]

  // Phase 7: family-meal membership
  familyMealMembers ComposedFamilyMealPlate[]

  @@index([userId, createdAt])
  @@map("composed_plates")
}

// Group 10X Phase 7: household roster — per-member dietary/age/pickiness so
// kid-vs-adult plates and family meals adapt to *this* family member, not a
// generic kid template (N=1 north star).
model HouseholdMember {
  id                 String   @id @default(cuid())
  userId             String // owning account
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName        String // "Mia (kid)" / "Alex" / "Mom"
  ageBand            String // "toddler" | "kid" | "teen" | "adult" | "elder"
  pickinessLevel     Int      @default(0) // 0..4 (0 = adventurous, 4 = beige-foods-only)
  dietaryFlags       String   @default("[]") // JSON: ["dairy_free", "no_spicy", "no_seafood"]
  bannedComponentIds String   @default("[]") // JSON: componentIds this member rejects outright
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  familyPlateAssignments ComposedFamilyMealPlate[]
  slotAffinities         SlotAffinity[]

  @@index([userId])
  @@map("household_members")
}

// Group 10X Phase 7: persisted family meal — N plates that belong to one
// cook event, with the merged cook-step plan persisted alongside.
model ComposedFamilyMeal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String? // "Sunday dinner" / auto-generated
  // Merged cook-step plan as JSON for fast read on the cook timeline.
  // Shape: [{componentId, totalPortions, servesPlateIds, slot}, ...]
  cookStepsJson String
  createdAt     DateTime @default(now())

  plates ComposedFamilyMealPlate[]

  @@index([userId, createdAt])
  @@map("composed_family_meals")
}

// Join row — one ComposedPlate participates in one ComposedFamilyMeal,
// optionally assigned to a HouseholdMember (kid plate vs adult plate).
model ComposedFamilyMealPlate {
  id                String             @id @default(cuid())
  familyMealId      String
  familyMeal        ComposedFamilyMeal @relation(fields: [familyMealId], references: [id], onDelete: Cascade)
  plateId           String
  plate             ComposedPlate      @relation(fields: [plateId], references: [id], onDelete: Cascade)
  householdMemberId String?
  householdMember   HouseholdMember?   @relation(fields: [householdMemberId], references: [id], onDelete: SetNull)
  positionIndex     Int // 0..N-1 column order in the composer

  @@unique([familyMealId, plateId])
  @@index([familyMealId])
  @@index([plateId])
  @@map("composed_family_meal_plates")
}

// Group 10Y: Sazon Coach — conversational AI nutrition + cooking companion.
model CoachConversation {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String // Auto-generated, injects user signals (cuisine affinity, goal phase)
  tier          String // "free" | "premium" — recorded at creation
  createdAt     DateTime       @default(now())
  lastMessageAt DateTime       @default(now())
  messages      CoachMessage[]

  @@index([userId, lastMessageAt])
  @@map("coach_conversations")
}

model CoachMessage {
  id               String            @id @default(cuid())
  conversationId   String
  conversation     CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  role             String // "user" | "assistant"
  content          String // Text content
  attachments      String            @default("[]") // JSON array of attachment descriptors
  thinkingTokens   Int?
  modelUsed        String?
  promptTokens     Int               @default(0)
  completionTokens Int               @default(0)
  cacheReadTokens  Int               @default(0)
  cacheWriteTokens Int               @default(0)
  createdAt        DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@map("coach_messages")
}

// Group 10Y Phase 6: Coach memory — long-term per-user notes that Sazon learns
// across conversations. Pro-only at injection time.
model CoachMemory {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind                 String // "preference" | "goal" | "constraint" | "milestone"
  content              String
  confidence           Float    @default(0.7)
  sourceConversationId String?
  sourceMessageId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId, updatedAt])
  @@map("coach_memories")
}

// Branded/restaurant food item cache (Group 10L)
model FoodItem {
  id          String   @id @default(cuid())
  name        String // "Round Table Pepperoni Pizza (1 slice)"
  brand       String? // "Round Table"
  category    String? // "restaurant" | "packaged" | "fast_food"
  servingSize String? // "1 slice (125g)"
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  source      String // "nutritionix" | "openfoodfacts" | "user"
  externalId  String? // Nutritionix item_id or OFF barcode for dedup
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meals       Meal[]

  @@unique([source, externalId])
  @@index([name])
  @@map("food_items")
}

// ─── ROADMAP 4.0 Tier B — Personalization Loop Closure ────────────────────────
// B1 — Per-user signal coverage telemetry.
// Daily snapshot of how much personalization signal a user has generated over
// a rolling window. Drives "low-signal user" interventions and the cohort
// distance metric (B2).
// `period` is the window size in days (7 | 30 | 90). `computedAt` is when the
// snapshot was taken; the snapshot covers (computedAt - period, computedAt].
model UserSignalSnapshot {
  id                     String   @id @default(cuid())
  userId                 String
  period                 Int // window size in days (7 | 30 | 90)
  cooks                  Int      @default(0)
  ratings                Int      @default(0)
  swaps                  Int      @default(0)
  utterances             Int      @default(0)
  leftoverDecisions      Int      @default(0)
  photoUploads           Int      @default(0)
  tasteFeedback          Int      @default(0)
  cravingSearches        Int      @default(0)
  preCookCheckIns        Int      @default(0)
  postCookNutritionViews Int      @default(0)
  totalSignals           Int      @default(0)
  computedAt             DateTime @default(now())

  @@unique([userId, period, computedAt])
  @@index([userId, computedAt])
  @@map("user_signal_snapshots")
}

// B2 — Cohort distance metric.
// Weekly aggregate of pairwise Jaccard distance between users' Today hero
// recommendation sets at d7/d30/d90 lookbacks. If the median distance isn't
// increasing over time, personalization is converging (broken).
// `cohortId` is a stable bucket name (e.g., "all", "premium", "lifestyle").
model CohortDistanceSnapshot {
  id         String   @id @default(cuid())
  cohortId   String
  asOfDate   DateTime
  d7Median   Float
  d30Median  Float
  d90Median  Float
  sampleSize Int
  createdAt  DateTime @default(now())

  @@unique([cohortId, asOfDate])
  @@index([cohortId, asOfDate])
  @@map("cohort_distance_snapshots")
}

// B3 — Per-surface signal-yield instrumentation.
// Single event log for every recommendation surface in the app. Action funnel:
// impression → tap → cook → rate. Daily aggregation lives in
// SurfaceYieldSnapshot below. Surfaces with low yield are noise — kill or
// rework.
// `surface` enum (string): today_hero | week_swap | kitchen_discover |
// sazon_tool | smart_collection | cravings_made_real | new_to_you |
// browse_by_family | other.
model SurfaceEvent {
  id        String   @id @default(cuid())
  userId    String
  surface   String
  recipeId  String?
  action    String // impression | tap | cook | rate
  variant   String? // B4 — algorithmic A/B variant key, optional
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([surface, createdAt])
  @@index([surface, action, createdAt])
  @@map("surface_events")
}

// B3 — Daily roll-up of SurfaceEvent funnel per surface.
// Computed daily by surfaceYieldService.
model SurfaceYieldSnapshot {
  id          String   @id @default(cuid())
  surface     String
  asOfDate    DateTime
  variant     String? // null = aggregate; non-null = per-variant for B4
  impressions Int      @default(0)
  taps        Int      @default(0)
  cooks       Int      @default(0)
  rates       Int      @default(0)
  signalYield Float    @default(0) // (cooks + rates) / max(impressions, 1)
  createdAt   DateTime @default(now())

  @@unique([surface, asOfDate, variant])
  @@index([surface, asOfDate])
  @@map("surface_yield_snapshots")
}

// C3 — Adjacency writeback.
// Signal-driven adjustments to the cuisine adjacency graph. Currently the
// adjacency table (utils/cuisineAdjacency.ts) is a hand-curated static graph;
// this layer adds dynamic per-edge weight updates driven by impression+tap
// pairs and other surface events. Aggregated globally first; per-user
// writeback is v1.1 (F4 backlog).
model CuisineAdjacencyWeight {
  id            String   @id @default(cuid())
  sourceCuisine String
  targetCuisine String
  weight        Float    @default(0)
  signalCount   Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([sourceCuisine, targetCuisine])
  @@index([sourceCuisine])
  @@map("cuisine_adjacency_weights")
}

// F4 — Per-user adjacency weights v2.
// Sibling table to CuisineAdjacencyWeight that captures per-user signal
// strengths. Used to bias recommendations toward each user's individual
// adjacency map (one user may strongly bond Persian↔Lebanese while another
// keeps them separate). Read-time blending: 70% global + 30% per-user when
// per-user signal count >= 3, otherwise fall back to global only.
model UserCuisineAdjacencyWeight {
  id            String   @id @default(cuid())
  userId        String
  sourceCuisine String
  targetCuisine String
  weight        Float    @default(0)
  signalCount   Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([userId, sourceCuisine, targetCuisine])
  @@index([userId])
  @@index([userId, sourceCuisine])
  @@map("user_cuisine_adjacency_weights")
}

// ROADMAP 4.0 G2.3 — "What I ate" travel journal.
// Per-user log of dishes eaten while traveling. Default private; opt-in
// to share with friends (F1) or contribute anonymized to the global
// adjacency model. Each entry can carry a free-text note + photo + cuisine
// tag; the cuisine tag drives a high-signal adjacency writeback when present.
model TravelJournalEntry {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  occurredAt              DateTime  @default(now())
  /// City slug from cityCuisineCatalog (e.g. "cdmx"). NULL = unknown city.
  citySlug                String?
  dishName                String
  cuisineTag              String?
  photoUri                String?
  note                    String?
  isPrivate               Boolean   @default(true)
  sharedWithFriendsAt     DateTime?
  contributedAnonymizedAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([userId, occurredAt])
  @@index([userId, citySlug])
  @@map("travel_journal_entries")
}

// ROADMAP 4.0 G2.4 — Founder-trip curation tasks.
// Internal-only admin tooling. When founder/team travels, the trip
// generates structured curation tasks (review N ingredients for {locale},
// photograph + tag M produce items, record cultural-primer voice memo).
// Funds the I2 catalog with first-hand provenance, not LLM hallucination.
model LocalCurationTask {
  id             String    @id @default(cuid())
  /// Admin who created/owns the task.
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// BCP 47 locale this task augments (e.g. "es-MX", "pt-BR").
  locale         String
  /// City slug from cityCuisineCatalog when applicable.
  citySlug       String?
  /// Type of curation work: review_ingredients | photograph_produce | cultural_primer_voice_memo
  taskType       String
  targetCount    Int       @default(0)
  completedCount Int       @default(0)
  /// pending | in_progress | completed | abandoned
  status         String    @default("pending")
  notes          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, status])
  @@index([locale, status])
  @@map("local_curation_tasks")
}

// C12 — Adaptive notification log.
// Cadence-aware push: only at the user's typical cook hour, max 3/day,
// content adapts to pantry + remaining macros + cuisine variety state.
model AdaptiveNotificationLog {
  id          String    @id @default(cuid())
  userId      String
  sentAt      DateTime  @default(now())
  template    String // logical template id, e.g. "expiring-pantry"
  signalsUsed String // JSON snapshot of signals that drove the choice
  tapped      Boolean   @default(false)
  tappedAt    DateTime?

  @@index([userId, sentAt])
  @@index([template, sentAt])
  @@map("adaptive_notification_logs")
}

// C6 — Adaptive nutrition coverage snapshot.
// Weekly aggregate of macro + micro adherence + gap signals. Drives the
// "more variety" / "more fiber" invitations on Today + Weekly Recap.
// Power-user mode also includes a macroAdjustment field with the suggested
// daily target delta (the MacroFactor pattern, opt-in).
model NutritionCoverageSnapshot {
  id                String   @id @default(cuid())
  userId            String
  period            Int // window size in days (typically 14)
  asOfDate          DateTime
  // Macro adherence (% of daily target hit, averaged over the window).
  caloriesAdherence Float    @default(0)
  proteinAdherence  Float    @default(0)
  fiberAdherence    Float    @default(0)
  // JSON-string array of gap labels we detected in the window
  // ("fiber", "iron", "magnesium", "variety", "consistency").
  gaps              String   @default("[]")
  // Optional power-user macro adjustment suggestion. JSON shape:
  // {calories?: number, protein?: number, reason: string} where the deltas
  // are the new daily target minus the old. null when not applicable.
  macroAdjustment   String?
  computedAt        DateTime @default(now())

  @@unique([userId, period, asOfDate])
  @@index([userId, asOfDate])
  @@map("nutrition_coverage_snapshots")
}

// C7 — Daily check-in.
// 3-tap, 10s max. Top half: today's nutrition card snapshot (the discovery
// view). Bottom half: 1 conversational reflection. The data + reflection
// pair is the highest-fidelity adaptation signal in the stack.
// Hunger + energy are 1..5 Likert scales (1 = very low, 5 = very high).
model DailyCheckIn {
  id                   String   @id @default(cuid())
  userId               String
  date                 DateTime
  // JSON snapshot of the nutrition card the user tapped on. Optional — user
  // can submit reflection without expanding the card.
  nutritionSnapshot    String?
  reflectionText       String?
  hungerNow            Int?
  energyAtLastMeal     Int?
  satietyFromYesterday Int?
  createdAt            DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_check_ins")
}

// ──────────────────────────────────────────────────────────────────────────
// ROADMAP 4.0 D12 — USDA FoodData Central nutrition cache.
//
// IngredientNutrient stores the normalized per-100g profile for a single
// FDC food item. IngredientFDCMapping caches "this ingredient name maps to
// that FDC ID" so we look up FDC at most once per ingredient.
//
// The discovery surface (D14) reads the columned macros + 25 most-relevant
// micros directly. The long tail of nutrients (~120 more, per FDC) lives
// in `extras` as JSON for occasional access without bloating queries.
// ──────────────────────────────────────────────────────────────────────────

model IngredientNutrient {
  id          String  @id @default(cuid())
  fdcId       Int     @unique
  description String
  category    String?
  servingSize Float   @default(100)
  servingUnit String  @default("g")

  // Macros (per 100g, kcal/g — same units USDA uses)
  calories     Float?
  protein      Float?
  carbs        Float?
  fat          Float?
  fiber        Float?
  sugar        Float?
  addedSugar   Float?
  saturatedFat Float?
  monoFat      Float?
  polyFat      Float?
  transFat     Float?
  cholesterol  Float?

  // Minerals (mg unless noted)
  sodium     Float?
  potassium  Float?
  calcium    Float?
  iron       Float?
  magnesium  Float?
  zinc       Float?
  phosphorus Float?
  selenium   Float? // mcg

  // Vitamins
  vitA       Float? // mcg RAE
  vitC       Float? // mg
  vitD       Float? // mcg
  vitE       Float? // mg
  vitK       Float? // mcg
  thiamin    Float? // B1, mg
  riboflavin Float? // B2, mg
  niacin     Float? // B3, mg
  b6         Float? // mg
  b12        Float? // mcg
  folate     Float? // mcg DFE

  // Omegas (g)
  omega3 Float?
  omega6 Float?

  // Long tail — JSON map of nutrient_id → { value, unit, name }
  extras String?

  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mappings IngredientFDCMapping[]

  @@map("ingredient_nutrients")
}

model IngredientFDCMapping {
  id             String             @id @default(cuid())
  normalizedName String             @unique
  fdcId          Int
  ingredient     IngredientNutrient @relation(fields: [fdcId], references: [fdcId], onDelete: Cascade)
  confidence     Float              @default(1.0)
  createdAt      DateTime           @default(now())

  @@index([fdcId])
  @@map("ingredient_fdc_mappings")
}

// ──────────────────────────────────────────────────────────────────────────
// ROADMAP 4.0 D13 — Recipe + daily nutrient aggregation.
//
// RecipeNutrientAggregate: per-recipe per-serving roll-up across the
// recipe's ingredients (lazy-cached, invalidated on recipe edit).
//
// DailyNutrientSnapshot: per-user per-date sum across that day's
// CookingLog entries. Recomputed on cook-log write or daily refresh.
//
// Both tables mirror the IngredientNutrient column shape so the discovery
// UI (D14) can read aggregates with a single row-level query.
// ──────────────────────────────────────────────────────────────────────────

model RecipeNutrientAggregate {
  id       String @id @default(cuid())
  recipeId String @unique
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  servings Int    @default(1)

  // Per-serving aggregates — same units / shape as IngredientNutrient
  calories     Float?
  protein      Float?
  carbs        Float?
  fat          Float?
  fiber        Float?
  sugar        Float?
  addedSugar   Float?
  saturatedFat Float?
  monoFat      Float?
  polyFat      Float?
  transFat     Float?
  cholesterol  Float?
  sodium       Float?
  potassium    Float?
  calcium      Float?
  iron         Float?
  magnesium    Float?
  zinc         Float?
  phosphorus   Float?
  selenium     Float?
  vitA         Float?
  vitC         Float?
  vitD         Float?
  vitE         Float?
  vitK         Float?
  thiamin      Float?
  riboflavin   Float?
  niacin       Float?
  b6           Float?
  b12          Float?
  folate       Float?
  omega3       Float?
  omega6       Float?

  // Coverage = fraction of ingredients we successfully resolved to FDC.
  // Lets the UI decide whether to surface "approximate" disclaimers.
  ingredientCoverage Float @default(0)

  computedAt  DateTime @default(now())
  invalidated Boolean  @default(false)

  @@map("recipe_nutrient_aggregates")
}

model DailyNutrientSnapshot {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   String // ISO 'YYYY-MM-DD' — SQLite-friendly, timezone-stable

  calories     Float?
  protein      Float?
  carbs        Float?
  fat          Float?
  fiber        Float?
  sugar        Float?
  addedSugar   Float?
  saturatedFat Float?
  monoFat      Float?
  polyFat      Float?
  transFat     Float?
  cholesterol  Float?
  sodium       Float?
  potassium    Float?
  calcium      Float?
  iron         Float?
  magnesium    Float?
  zinc         Float?
  phosphorus   Float?
  selenium     Float?
  vitA         Float?
  vitC         Float?
  vitD         Float?
  vitE         Float?
  vitK         Float?
  thiamin      Float?
  riboflavin   Float?
  niacin       Float?
  b6           Float?
  b12          Float?
  folate       Float?
  omega3       Float?
  omega6       Float?

  mealCount  Int      @default(0)
  computedAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_nutrient_snapshots")
}

// ──────────────────────────────────────────────────────────────────────────
// ROADMAP 4.0 F1 — "Cook a friend's plate" social graph.
// Follow is one-directional; unique on (followerId, followingId).
// ──────────────────────────────────────────────────────────────────────────

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("FollowerRelation", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("FollowingRelation", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

// ──────────────────────────────────────────────────────────────────────────
// Pre-launch waitlist (sazonchef.com landing page).
// Captures email + 3 quick selects so day-1 taste_profile can be pre-seeded
// at signup. See plans/launch-marketing.md for the spec.
// ──────────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────────
// ROADMAP 4.0 D7 — Recipe deletion audit log.
// One row per soft delete; preserved for 30 days (hardDeleteAfter) so
// triage decisions are reversible until then. `reasonCodes` is JSON.
// ──────────────────────────────────────────────────────────────────────────

model RecipeDeletion {
  id              String   @id @default(cuid())
  recipeId        String   @unique
  recipe          Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  composite       Float
  suggestedAction String // 'delete_candidate' | 'rebuild_required'
  reasonCodes     String   @default("[]") // JSON array of FailureReason codes
  isOnlyInstance  Boolean  @default(false)
  softDeletedAt   DateTime @default(now())
  hardDeleteAfter DateTime

  @@index([softDeletedAt])
  @@index([hardDeleteAfter])
  @@map("recipe_deletions")
}

// ──────────────────────────────────────────────────────────────────────────
// ROADMAP 4.0 D2 — Recipe quality scorecard.
// Composite (0-100) + 6 axis scores (each 0-5, nullable) + JSON failure
// reasons. One row per recipe; idempotent upsert via `recipeId @unique`.
// Engagement signals deliberately excluded — content-only scoring protects
// breadth (see ROADMAP_4.0.md Tier D preamble).
// ──────────────────────────────────────────────────────────────────────────

model RecipeQualityScore {
  id             String   @id @default(cuid())
  recipeId       String   @unique
  recipe         Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  composite      Float
  imageScore     Float?
  structureScore Float?
  nutritionScore Float?
  voiceScore     Float?
  dedupeScore    Float?
  safetyScore    Float?
  failureReasons String   @default("[]") // JSON-encoded {axis, code, detail}[]
  scoredAt       DateTime @default(now())

  @@index([composite])
  @@index([scoredAt])
  @@map("recipe_quality_scores")
}

model WaitlistSignup {
  id          String    @id @default(cuid())
  email       String    @unique
  topCuisine  String?
  macroGoal   String? // 'lighter' | 'strong_lean' | 'flavor_balanced' | 'discovery'
  dietary     String    @default("[]") // JSON-encoded string array
  source      String? // utm_source / referrer for attribution
  createdAt   DateTime  @default(now())
  invitedAt   DateTime?
  convertedAt DateTime?

  @@index([createdAt])
  @@map("waitlist_signups")
}

// ROADMAP 4.0 TB3.1 — recommender proposal logging.
// Every Tonight proposal writes one RecommenderEvent. Outcomes
// (accepted / swapped / escaped / abandoned) backfill via
// RecommenderEventOutcome from the analytics event handler.
model RecommenderEvent {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asOf            DateTime
  contextSnapshot String // JSON-stringified user context at proposal time
  candidateIds    String // JSON-stringified string[]
  pickedRecipeId  String?
  pickedRecipe    Recipe?  @relation("PickedRecipe", fields: [pickedRecipeId], references: [id], onDelete: SetNull)
  confidence      Float
  copyLine        String // The reason / copy line returned to client
  source          String // 'llm' | 'retrieval_fallback'
  createdAt       DateTime @default(now())

  outcome   RecommenderEventOutcome?
  runnerUps RecommenderRunnerUp[]

  @@index([userId, createdAt])
  @@index([pickedRecipeId])
  @@map("recommender_events")
}

model RecommenderRunnerUp {
  id       String           @id @default(cuid())
  eventId  String
  event    RecommenderEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recipeId String
  recipe   Recipe           @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rank     Int

  @@unique([eventId, rank])
  @@index([eventId])
  @@map("recommender_runner_ups")
}

// ROADMAP 4.0 TB3.2 — outcome backfill written when the user
// accepts / swaps / escapes / abandons. Idempotent on duplicate event id.
model RecommenderEventOutcome {
  id        String           @id @default(cuid())
  eventId   String           @unique
  event     RecommenderEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  outcome   String // 'accepted' | 'swapped' | 'escaped' | 'abandoned'
  latencyMs Int
  createdAt DateTime         @default(now())

  @@index([outcome])
  @@map("recommender_event_outcomes")
}

// ROADMAP 4.0 IG0.2 — Append-only ingredient event stream. Single source of
// truth for pantry / shopping / cooking ingredient interactions. Powers
// IG2 (co-purchase), IG3 (depletion cadence), IG6 (swap learning), IG9
// (logging + counterfactual).
model IngredientEvent {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredientName String // canonical name; pre-normalize at write site
  eventType      String // addedToPantry | addedToShoppingList | purchased | consumed | expired | swappedIn | swappedOut | removedManually
  quantity       Float?
  unit           String?
  recipeId       String?
  swapTargetName String? // for swappedIn/Out events: the partner ingredient name
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([userId, occurredAt])
  @@index([userId, ingredientName, occurredAt])
  @@index([userId, eventType, occurredAt])
  @@map("ingredient_events")
}

// ROADMAP 4.0 IG2.1 — Sparse per-user ingredient co-occurrence matrix.
// Populated by a nightly job that windows IngredientEvent (purchased +
// consumed) into 7-day baskets and increments pair counts. The pair key is
// canonical: ingredientA < ingredientB lexicographically. Per-user so
// signals stay personal (cross-user aggregation goes through IG2.x v2 with
// k-anonymity).
model IngredientCoOccurrence {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredientA String // lexicographically smaller name
  ingredientB String // lexicographically larger name
  coCount     Float    @default(0) // float to support fractional decay
  lastSeenAt  DateTime
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([userId, ingredientA, ingredientB])
  @@index([userId, ingredientA])
  @@index([userId, ingredientB])
  @@map("ingredient_co_occurrence")
}

// ROADMAP 4.0 IG3.1 — Per-user × per-ingredient cadence snapshot. Updated
// nightly from purchased-type IngredientEvent rows. Cold-start (≤ 2 events)
// reads `confidence: 'low'` and downstream predictRunningLow tightens its
// threshold accordingly.
model IngredientCadence {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredientName   String // canonical
  meanIntervalDays Float? // null = cold-start
  stdDevDays       Float?
  lastPurchasedAt  DateTime?
  sampleCount      Int       @default(0)
  confidence       String    @default("low") // 'low' | 'medium' | 'high'
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  @@unique([userId, ingredientName])
  @@index([userId])
  @@map("ingredient_cadence")
}

// ROADMAP 4.0 IG0.3 — Ingredient embeddings. One row per canonical name
// (pre-normalized via normalizeIngredientName). Mirrors RecipeEmbedding shape.
// Powers IG1 (semantic similarity) + IG6 (learned swap fallback) + IG7
// (semantic pantry match).
model IngredientEmbedding {
  id            String   @id @default(cuid())
  canonicalName String   @unique
  embedding     Bytes // Float32Array serialized as bytes
  model         String // model id, e.g. 'text-embedding-3-small'
  dimensions    Int
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@index([canonicalName])
  @@map("ingredient_embeddings")
}

// ROADMAP 4.0 IG9.2 — Daily rollup of ingredient-surface recommender events.
// Aggregates the unified RecommenderEvent stream (ingredient_recommend /
// ingredient_co_purchase / pantry_iq) into per-user-per-day acceptance rates
// per source. Powers the IG10 Pantry IQ surface and Tier M weekly synthesis.
//
// TTL: raw RecommenderEvent rows expire at 90 days
// (TELEMETRY_CONTRACT.rawEventTtlDays). This roll-up is retained indefinitely
// so longitudinal trends survive raw-event purge.
model IngredientRecommenderDaily {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime // start-of-day UTC
  source         String // 'cadence' | 'co_purchase' | 'embedding' | 'static' | 'user' | 'crowd' | 'cultural'
  impressions    Int      @default(0)
  taps           Int      @default(0)
  accepts        Int      @default(0)
  dismisses      Int      @default(0)
  // Acceptance rate = accepts / impressions, computed at write time. Null when
  // impressions == 0 (impossible by construction but kept defensive).
  acceptanceRate Float?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([userId, date, source])
  @@index([userId, date])
  @@map("ingredient_recommender_daily")
}
