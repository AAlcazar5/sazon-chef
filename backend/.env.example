# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3001
HOST=0.0.0.0

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=30d            # 7d | 30d | 90d (jsonwebtoken duration string) [legacy]

# Tier L H2 — refresh-token strategy. ACCESS_TOKEN_EXPIRES_IN is the JWT TTL
# returned in the new `accessToken` field; REFRESH_TOKEN_EXPIRES_DAYS is the
# server-side refresh-token TTL in days. Short access + longer refresh +
# single-use rotation is the recommended posture; tune only with cause.
ACCESS_TOKEN_EXPIRES_IN=15m   # jsonwebtoken duration string
REFRESH_TOKEN_EXPIRES_DAYS=7

# ─── AI Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...

# ─── External APIs ───────────────────────────────────────────────────────────
SPOONACULAR_API_KEY=...
UNSPLASH_ACCESS_KEY=...
UNSPLASH_SECRET_KEY=...

# ─── Cloudinary (image uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ─── Social Auth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
APPLE_CLIENT_ID=...
APPLE_TEAM_ID=...
APPLE_KEY_ID=...
APPLE_PRIVATE_KEY_PATH=...

# ─── CORS ────────────────────────────────────────────────────────────────────
# Production: set to your app's origin (e.g. https://sazonchef.com)
# Dev: leave unset — all origins are allowed automatically
FRONTEND_URL=https://sazonchef.com

# ─── Monitoring ──────────────────────────────────────────────────────────────
# Sentry DSN from https://sentry.io — leave blank to disable error tracking
SENTRY_DSN=

# ─── Caching (Group 3 — Upstash Redis) ───────────────────────────────────────
# Get from https://upstash.com — leave blank to fall back to in-memory cache
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ─── Push Notifications (Group 6 — Expo Push) ──────────────────────────────
# Optional: for authenticated push sending (higher rate limits)
# Get from https://expo.dev → Account Settings → Access Tokens
EXPO_ACCESS_TOKEN=

# ─── Email (Group 6 — Resend) ──────────────────────────────────────────────
# Get from https://resend.com/api-keys — leave blank to log emails to console
RESEND_API_KEY=
FROM_EMAIL=Sazon Chef <noreply@sazonchef.com>

# Tier L H3 — when set to 'true' or '1', login returns 403 EMAIL_NOT_VERIFIED
# for users with emailVerified=false (and the requireEmailVerified middleware
# blocks gated routes). Off by default so legacy accounts aren't locked out
# while the verification flow ramps. Flip on once the mobile client ships
# the verify-email wall.
REQUIRE_EMAIL_VERIFICATION=false

# ─── Stripe (Group 7) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_...

# ─── RevenueCat (mobile IAP) ────────────────────────────────────────────────
# Comma-separated SKUs that grant the Pro entitlement. Webhook auth header
# is the verbatim Authorization value RevenueCat sends; reject mismatches.
REVENUECAT_PREMIUM_PRODUCT_IDS=sazon.pro.monthly,sazon.pro.annual
REVENUECAT_WEBHOOK_AUTH_HEADER=Bearer change-me-in-production

# ─── Encryption at rest ─────────────────────────────────────────────────────
# 32-byte key (base64). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Used by src/utils/encryption.ts for emails + (B3) shopping-app credentials.
# CRITICAL: rotating this key without re-encrypting will break all stored data.
ENCRYPTION_KEY=

# ─── Logging ────────────────────────────────────────────────────────────────
# pino level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ─── LLM Providers (free + Pro routing) ─────────────────────────────────────
# Pro coach uses ANTHROPIC_API_KEY (Claude). Free coach falls back via the
# COACH_FREE_PROVIDER env to OpenRouter or Gemini direct.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-001
OPENROUTER_API_KEY=
OPENROUTER_FREE_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_REFERER=https://sazon.app

# Comma-separated provider order tried by AIProviderManager fallback chain
AI_PROVIDER_ORDER=claude,gemini,openrouter
COACH_LLM_PROVIDER=claude
COACH_FREE_PROVIDER=openrouter

# ─── Nutrition (USDA + Nutritionix) ─────────────────────────────────────────
# Both keys gate D12–D14 nutrition discovery; leaving blank degrades the
# Today nutrition strip + recipe-detail micronutrient panel.
FDC_API_KEY=
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# ─── Self-improvement engine (Tier M) ───────────────────────────────────────
# Master kill switch for the recursive observation → synthesis loop. False
# disables Sonnet weekly synthesis + AppFollow / RSS feeds.
SELF_IMPROVEMENT_ENGINE_ENABLED=false
APPFOLLOW_API_KEY=

# ─── Recommender (Tier T-bis) ───────────────────────────────────────────────
# Daily $ ceiling for the LLM ranker (TB2). Above this, fall through to
# rule-based scoring. RECOMMENDER_RETRIEVAL gates whether TB1 retrieval
# is wired in production.
RECOMMENDER_DAILY_BUDGET=5.00
RECOMMENDER_RETRIEVAL=off

# ─── Tonight Mode (Tier T) ──────────────────────────────────────────────────
# Feature flag for the single-screen "Sazon picks dinner" prototype.
SAZON_TONIGHT_MODE=off

# ─── Translations (i18n-OPS) ────────────────────────────────────────────────
DEEPL_API_KEY=

# ─── Weather (cuisine adjacency hints) ──────────────────────────────────────
OPENWEATHER_API_KEY=

# ─── Mobile deep linking ────────────────────────────────────────────────────
# URL scheme for app: links (e.g. "sazon" → sazon://recipe/abc123)
APP_SCHEME=sazon
